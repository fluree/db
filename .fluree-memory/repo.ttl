    mem:artifactRef "fluree-db-api/src/ledger_manager.rs" ;
    mem:artifactRef "fluree-db-api/src/loading.rs" ;
    mem:branch "feature/memory" ;
    mem:createdAt "2026-02-24T19:48:56.368004+00:00"^^xsd:dateTime .

mem:fact-01kj8k5nzpe59p5vp7zrehbrr9 a mem:Fact ;
    mem:content "Forward dictionary packing: replaced CoW B-tree forward dicts (many ~2MB DLF1 leaves) with large FPK1 pack files (~256MB). FPK1: 40-byte header + pages + directory, O(1) lookup via offset indexing. ForwardPackReader: mmap-backed, binary search by ID range.\n\nIRB1 root bumped to v2; DictPackRefs replaces forward tree refs; reverse dicts unchanged (DLF1 tree). Clean break — no backward compatibility with v1 forward trees.\nKey files: dict_tree/forward_pack.rs, pack_reader.rs, pack_builder.rs" ;
    mem:tag "dictionary" ;
    mem:tag "forward-dict" ;
    mem:tag "fpk1" ;
    mem:tag "mmap" ;
    mem:tag "pack-files" ;
    mem:tag "tsv-export" ;
